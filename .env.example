# Copy to .env and fill in. Never commit .env.
# The install script will source this file if it exists, otherwise it will
# prompt interactively.

# Required: Groq API key for the LLM post-processing step.
# Get one at https://console.groq.com/keys
GROQ_API_KEY=

# Optional: override config file values at runtime.
# All settings can be configured permanently in ~/.config/relay/config.toml.
# GROQ_MODEL=openai/gpt-oss-120b
# GROQ_ENDPOINT=https://api.groq.com/openai/v1/chat/completions
# REPHRASE_STYLE=Custom prompt for voxtype-rephrase
# SUMMARIZE_STYLE=Custom prompt for voxtype-summarize
# SUMMARIZE_MODEL=Custom model for voxtype-summarize
# SUMMARIZE_ENDPOINT=Custom endpoint for voxtype-summarize
#
# Default endpoint: https://api.groq.com/openai/v1/chat/completions
# GROQ_ENDPOINT=https://api.groq.com/openai/v1/chat/completions
