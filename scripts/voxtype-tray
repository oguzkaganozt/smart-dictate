#!/usr/bin/env python3
"""
voxtype-tray: system tray indicator for smart-dictate.

Shows a minimal monochrome microphone icon in the system tray:
  Bright -> voxtype service is active (listening)
  Dim    -> voxtype service is inactive

Left-click toggles the service (start / stop).  Right-click opens a
menu to start, stop, restart, or quit the indicator.

Autostarted via systemd user service (voxtype-tray.service).
Requires PyGObject + GTK3 + libayatana-appindicator (or Gtk.StatusIcon
fallback).
"""
import io
import math
import os
import shutil
import subprocess
import sys
import tempfile

import cairo
import gi

gi.require_version("Gtk", "3.0")
from gi.repository import GLib, Gtk, Gdk, GdkPixbuf  # noqa: E402

try:
    gi.require_version("AyatanaAppIndicator3", "0.1")
    from gi.repository import AyatanaAppIndicator3 as AppIndicator  # noqa: E402

    HAS_AYATANA = True
except (ValueError, ImportError):
    HAS_AYATANA = False

SERVICE = "voxtype.service"
POLL_SEC = 5
ICON_SIZE = 24


def _is_active() -> bool:
    r = subprocess.run(
        ["systemctl", "--user", "is-active", SERVICE],
        capture_output=True,
        text=True,
        timeout=5.0,
    )
    return r.stdout.strip() == "active"


def _render_surface(active: bool) -> cairo.ImageSurface:
    s = cairo.ImageSurface(cairo.FORMAT_ARGB32, ICON_SIZE, ICON_SIZE)
    cr = cairo.Context(s)

    cr.set_operator(cairo.OPERATOR_CLEAR)
    cr.paint()
    cr.set_operator(cairo.OPERATOR_OVER)

    cr.scale(ICON_SIZE / 24, ICON_SIZE / 24)
    cr.set_source_rgb(*(0.95, 0.95, 0.95) if active else (0.52, 0.52, 0.52))
    cr.set_line_width(2.2)
    cr.set_line_cap(cairo.LINE_CAP_ROUND)
    cr.set_line_join(cairo.LINE_JOIN_ROUND)

    x, y, w, h, rx = 8, 3, 8, 11, 4
    cr.new_sub_path()
    cr.arc(x + rx, y + rx, rx, math.pi, 3 * math.pi / 2)
    cr.arc(x + w - rx, y + rx, rx, 3 * math.pi / 2, 0)
    cr.arc(x + w - rx, y + h - rx, rx, 0, math.pi / 2)
    cr.arc(x + rx, y + h - rx, rx, math.pi / 2, math.pi)
    cr.close_path()
    cr.stroke()

    cr.move_to(12, 7)
    cr.line_to(12, 10)
    cr.stroke()

    cr.move_to(5.5, 11)
    cr.curve_to(5.5, 15.5, 8.4, 18, 12, 18)
    cr.curve_to(15.6, 18, 18.5, 15.5, 18.5, 11)
    cr.stroke()

    cr.move_to(12, 18)
    cr.line_to(12, 21)
    cr.move_to(8.5, 21)
    cr.line_to(15.5, 21)
    cr.stroke()

    return s


def _render_pixbuf(active: bool) -> GdkPixbuf.Pixbuf:
    return Gdk.pixbuf_get_from_surface(
        _render_surface(active), 0, 0, ICON_SIZE, ICON_SIZE
    )


def _render_png(active: bool) -> bytes:
    s = _render_surface(active)
    buf = io.BytesIO()
    s.write_to_png(buf)
    return buf.getvalue()


class TrayIndicator:
    def __init__(self) -> None:
        self._tmpdir = tempfile.mkdtemp(prefix="smart-dictate-")

        for name, active in [("active", True), ("inactive", False)]:
            png = _render_png(active)
            path = os.path.join(self._tmpdir, f"{name}.png")
            with open(path, "wb") as f:
                f.write(png)
        self._active_path = os.path.join(self._tmpdir, "active.png")
        self._inactive_path = os.path.join(self._tmpdir, "inactive.png")

        self.active = False

        if HAS_AYATANA:
            self._setup_ayatana()
        else:
            self._setup_statusicon()

        self._update()
        GLib.timeout_add_seconds(POLL_SEC, self._update)
        GLib.timeout_add_seconds(20, self._check_updates)

    def _setup_ayatana(self) -> None:
        self._indicator = AppIndicator.Indicator.new(
            "smart-dictate",
            "",
            AppIndicator.IndicatorCategory.APPLICATION_STATUS,
        )
        self._indicator.set_status(AppIndicator.IndicatorStatus.ACTIVE)
        self._indicator.set_icon_full(self._inactive_path, "smart-dictate: inactive")
        self._menu = Gtk.Menu()
        self._indicator.set_menu(self._menu)

    def _setup_statusicon(self) -> None:
        self._icon = Gtk.StatusIcon()
        self._icon.set_from_pixbuf(_render_pixbuf(False))
        self._icon.set_tooltip_text("smart-dictate: starting…")
        self._icon.connect("popup-menu", self._on_popup_menu)
        self._icon.connect("activate", self._on_activate)

    def _build_menu(self, menu: Gtk.Menu) -> None:
        for child in menu.get_children():
            menu.remove(child)
            child.destroy()

        status_text = "Active (listening)" if self.active else "Inactive"
        item = Gtk.MenuItem(label=status_text)
        item.set_sensitive(False)
        menu.append(item)

        menu.append(Gtk.SeparatorMenuItem())

        if not self.active:
            item = Gtk.MenuItem(label="Start")
            item.connect("activate", lambda *_: self._ctl("start"))
            menu.append(item)

        item = Gtk.MenuItem(label="Stop")
        item.connect("activate", lambda *_: self._ctl("stop"))
        menu.append(item)

        item = Gtk.MenuItem(label="Restart")
        item.connect("activate", lambda *_: self._ctl("restart"))
        menu.append(item)

        menu.append(Gtk.SeparatorMenuItem())

        item = Gtk.MenuItem(label="Calibrate Microphone")
        item.connect("activate", lambda *_: self._calibrate())
        menu.append(item)

        item = Gtk.MenuItem(label="Upgrade Smart Dictate")
        item.connect("activate", lambda *_: self._upgrade())
        menu.append(item)

        menu.append(Gtk.SeparatorMenuItem())

        item = Gtk.MenuItem(label="Quit")
        item.connect("activate", lambda *_: Gtk.main_quit())
        menu.append(item)

        menu.show_all()

    def _on_popup_menu(
        self, icon: Gtk.StatusIcon, button: int, activate_time: int
    ) -> None:
        menu = Gtk.Menu()
        self._build_menu(menu)
        menu.popup(
            None, None, Gtk.StatusIcon.position_menu, icon, button, activate_time
        )

    def _on_activate(self, _icon: Gtk.StatusIcon) -> None:
        if self.active:
            self._ctl("stop")
        else:
            self._ctl("start")

    def _ctl(self, action: str) -> None:
        subprocess.Popen(
            ["systemctl", "--user", action, SERVICE],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
        GLib.timeout_add(500, self._update)

    def _calibrate(self) -> None:
        script = (
            "voxtype-calibrate-mic; status=$?; echo; "
            "echo Calibration exit code: $status; echo; "
            "read -r -p 'Press Enter to close...'"
        )
        self._open_terminal(script)

    def _upgrade(self) -> None:
        script = (
            "smart-dictate upgrade; status=$?; echo; "
            "echo Upgrade exit code: $status; echo; "
            "read -r -p 'Press Enter to close...'"
        )
        self._open_terminal(script)

    def _open_terminal(self, script: str) -> None:
        candidates = [
            ["gnome-terminal", "--", "bash", "-lc", script],
            ["kgx", "--", "bash", "-lc", script],
            ["x-terminal-emulator", "-e", "bash", "-lc", script],
        ]
        for cmd in candidates:
            if shutil.which(cmd[0]):
                subprocess.Popen(
                    cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
                )
                return
        subprocess.Popen(
            ["notify-send", "--app-name=smart-dictate", "Mic calibration",
             "No terminal emulator found."],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )

    def _check_updates(self) -> bool:
        if not shutil.which("smart-dictate"):
            return False
        try:
            r = subprocess.run(
                ["smart-dictate", "check-updates", "--quiet"],
                capture_output=True,
                text=True,
                timeout=20.0,
            )
        except Exception:
            return False
        if r.returncode == 10:
            latest = r.stdout.strip() or "latest"
            subprocess.Popen(
                ["notify-send", "--app-name=smart-dictate", "Update available",
                 f"smart-dictate {latest} is available. Use the tray menu or run: smart-dictate upgrade"],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
            )
        return False

    def _update(self) -> bool:
        try:
            self.active = _is_active()
        except Exception:
            self.active = False

        label = "smart-dictate: active (listening)" if self.active else "smart-dictate: inactive"

        if HAS_AYATANA:
            self._indicator.set_icon_full(
                self._active_path if self.active else self._inactive_path,
                label,
            )
            self._indicator.set_label("", "")
            self._build_menu(self._menu)
        else:
            self._icon.set_from_pixbuf(_render_pixbuf(self.active))
            self._icon.set_tooltip_text(label)

        return True


def main() -> int:
    if "DISPLAY" not in os.environ and "WAYLAND_DISPLAY" not in os.environ:
        print(
            "voxtype-tray: No display found.",
            file=sys.stderr,
        )
        return 1

    Gtk.init()
    TrayIndicator()
    Gtk.main()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
