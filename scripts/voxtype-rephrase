#!/usr/bin/env python3
import json
import os
from pathlib import Path
import subprocess
import sys
import time
import urllib.error
import urllib.request

CONFIG_PATH = Path.home() / ".config" / "smart-dictate" / "config.toml"
KEY_FILE = Path.home() / ".config" / "voxtype" / "groq-api-key"
LOG = Path("/tmp") / "voxtype-rephrase.log"


def log(msg: str) -> None:
    try:
        with open(LOG, "a") as f:
            f.write(f"{time.strftime('%H:%M:%S')} {msg}\n")
    except Exception:
        pass


def _load_config() -> dict:
    cfg = {"groq": {}, "rephrase": {}}
    if CONFIG_PATH.exists():
        try:
            import tomllib
            with open(CONFIG_PATH, "rb") as f:
                data = tomllib.load(f)
            if "groq" in data:
                cfg["groq"] = data["groq"]
            if "rephrase" in data:
                cfg["rephrase"] = data["rephrase"]
        except Exception:
            pass
    return cfg


_cfg = _load_config()

MODEL = (
    os.environ.get("REPHRASE_MODEL")
    or _cfg["rephrase"].get("model")
    or os.environ.get("GROQ_MODEL")
    or _cfg["groq"].get("model", "qwen/qwen3.6-27b")
)
ENDPOINT = (
    os.environ.get("REPHRASE_ENDPOINT")
    or _cfg["rephrase"].get("endpoint")
    or os.environ.get("GROQ_ENDPOINT")
    or _cfg["groq"].get("endpoint", "https://api.groq.com/openai/v1/chat/completions")
)

DEFAULT_PROMPT = (
    "You are an experienced editor. Rewrite the text to be more fluent, "
    "natural, and concise. Remove redundancy, filler, and unnecessary "
    "words while preserving ALL key information, data, technical terms, "
    "commands, file paths, and code names unchanged. The output should be "
    "substantially shorter but still complete in meaning and context. "
    "PRESERVE THE ORIGINAL LANGUAGE: if the input is in Turkish, output in "
    "Turkish; if English, output in English. "
    "Output only the rewritten text, no explanations."
)
SYSTEM_PROMPT = os.environ.get("REPHRASE_STYLE") or _cfg["rephrase"].get("system_prompt", DEFAULT_PROMPT)

DEFAULT_USER_PROMPT = "Rewrite this text more clearly:\n\n{text}"
USER_PROMPT = _cfg["rephrase"].get("user_prompt", DEFAULT_USER_PROMPT)


def get_selected_text() -> str:
    for sel in ["primary", "clipboard"]:
        result = subprocess.run(
            ["xclip", "-o", "-selection", sel],
            capture_output=True, text=True, timeout=2.0,
        )
        if result.returncode == 0 and result.stdout.strip():
            log(f"read from {sel}: {len(result.stdout.strip())} chars")
            return result.stdout.strip()
    log("no text found in PRIMARY or CLIPBOARD")
    return ""


def get_api_key() -> str:
    key = os.environ.get("GROQ_API_KEY")
    if key:
        return key
    key = _cfg["groq"].get("api_key", "")
    if key:
        return key
    if KEY_FILE.exists():
        return KEY_FILE.read_text(encoding="utf-8").strip()
    return ""


def rephrase(text: str) -> str:
    user = USER_PROMPT.format(text=text)
    api_key = get_api_key()
    if not api_key:
        raise RuntimeError("GROQ_API_KEY is not configured")
    TPM_BUDGET = 8000
    PROMPT_OVERHEAD = 600
    input_tokens = len(user) // 4 + len(SYSTEM_PROMPT) // 4 + 20
    max_out = max(512, TPM_BUDGET - input_tokens - PROMPT_OVERHEAD)
    payload = {
        "model": MODEL,
        "messages": [
            {"role": "system", "content": SYSTEM_PROMPT},
            {"role": "user", "content": user},
        ],
        "temperature": 0.3,
        "max_completion_tokens": min(max_out, 4096),
    }
    if MODEL.startswith("openai/gpt-oss"):
        payload["reasoning_effort"] = "low"
    elif MODEL.startswith("qwen/"):
        payload["reasoning_effort"] = "none"
    req = urllib.request.Request(
        ENDPOINT,
        data=json.dumps(payload).encode("utf-8"),
        headers={
            "Authorization": f"Bearer {api_key}",
            "Content-Type": "application/json",
            "User-Agent": "voxtype-rephrase/1.0",
        },
    )
    with urllib.request.urlopen(req, timeout=5.0) as response:
        data = json.loads(response.read().decode("utf-8"))
    choices = data.get("choices") or []
    output = choices[0].get("message", {}).get("content", "").strip() if choices else ""
    output = output.strip('"').strip()
    log(f"rephrase output: {len(output)} chars")
    return output


def _notify(text: str) -> None:
    MAX_LEN = 100
    body = text[:MAX_LEN].replace("\n", " ").strip()
    if len(text) > MAX_LEN:
        body += "..."
    try:
        subprocess.run(
            ["notify-send", "--icon=edit-paste",
             "--app-name=smart-dictate", "D\xfczeltildi", body],
            timeout=3.0, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        )
    except Exception:
        pass


def _notify_err(msg: str) -> None:
    try:
        subprocess.run(
            ["notify-send", "--icon=edit-paste",
             "--app-name=smart-dictate", "Hata", msg],
            timeout=3.0, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        )
    except Exception:
        pass


TERMINAL_MARKERS = (
    "terminal", "console", "ptyxis", "kgx", "konsole", "tilix",
    "kitty", "alacritty", "wezterm", "ghostty",
)


def _is_terminal(wid: str) -> bool:
    """True if the active window looks like a terminal (needs ctrl+shift+v)."""
    if not wid:
        return False
    parts = []
    for cmd in (
        ["xdotool", "getwindowclassname", wid],
        ["xdotool", "getwindowname", wid],
        ["xprop", "-id", wid, "WM_CLASS"],
    ):
        try:
            r = subprocess.run(cmd, capture_output=True, text=True, timeout=2.0)
            parts.append(r.stdout)
        except Exception:
            pass
    hay = " ".join(parts).lower()
    return any(m in hay for m in TERMINAL_MARKERS)


def paste_text(text: str) -> None:
    wid = subprocess.run(
        ["xdotool", "getactivewindow"],
        capture_output=True, text=True, timeout=2.0,
    ).stdout.strip()
    subprocess.run(
        ["xclip", "-selection", "clipboard"],
        input=text.encode(), timeout=2.0,
    )
    time.sleep(0.1)
    if wid:
        subprocess.run(
            ["xdotool", "windowactivate", "--sync", wid],
            capture_output=True, timeout=5.0,
        )
        time.sleep(0.05)
    key = "ctrl+shift+v" if _is_terminal(wid) else "ctrl+v"
    subprocess.run(["xdotool", "key", key], timeout=5.0)
    log(f"pasted {len(text)} chars via {key}")





def main() -> int:
    log("=== start ===")

    text = get_selected_text()
    if not text:
        _notify_err("Metin bulunamad\u0131")
        return 1

    if len(text) > 20000:
        _notify_err(f"Metin \xe7ok uzun ({len(text)} karakter, max 20000)")
        return 1

    try:
        output = rephrase(text)
    except urllib.error.HTTPError as e:
        log(f"HTTP error: {e.code} {e.reason}")
        if e.code == 413:
            _notify_err(f"Metin \xe7ok uzun ({len(text)} karakter)")
        else:
            _notify_err(f"HTTP {e.code}")
        paste_text(text)
        return 1
    except Exception as e:
        log(f"API error: {e}")
        _notify_err(f"API: {type(e).__name__}")
        paste_text(text)
        return 1

    if not output:
        log("empty response")
        _notify_err("Groq yan\u0131t vermedi")
        paste_text(text)
        return 1

    paste_text(output)
    _notify(output)
    log("=== done ===")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
