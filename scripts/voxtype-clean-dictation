#!/usr/bin/env python3
"""
voxtype-clean-dictation: pipe stdin through Groq LLM for grammar cleanup.

Designed as the `[output.post_process].command` for VoxType. Receives
transcribed text on stdin and emits cleaned text on stdout.

Behavior:
- Short snippets (<90 chars / <14 words) pass through unchanged.
- Likely shell/code lines pass through unchanged.
- Otherwise, the text is sent to a Groq chat-completions call and the
  first choice is emitted.
- On any failure (timeout, HTTP error, parse error, oversized output),
  the original text is emitted unchanged so the daemon never blocks.

Auth (highest priority first):
- GROQ_API_KEY env var
- ~/.config/smart-dictate/config.toml → [groq] → api_key
- ~/.config/voxtype/groq-api-key file

Config precedence (highest first):
- Env var (GROQ_MODEL, GROQ_ENDPOINT)
- ~/.config/smart-dictate/config.toml
- Script defaults
"""
import json
import os
from pathlib import Path
import re
import subprocess
import sys
import urllib.error
import urllib.request


CONFIG_PATH = Path.home() / ".config" / "smart-dictate" / "config.toml"
KEY_FILE = Path.home() / ".config" / "voxtype" / "groq-api-key"


def _load_config() -> dict:
    cfg = {"groq": {}, "dictation": {}}
    if CONFIG_PATH.exists():
        try:
            import tomllib
            with open(CONFIG_PATH, "rb") as f:
                data = tomllib.load(f)
            if "groq" in data:
                cfg["groq"] = data["groq"]
            if "dictation" in data:
                cfg["dictation"] = data["dictation"]
        except Exception:
            pass
    return cfg


_cfg = _load_config()

MODEL = os.environ.get("GROQ_MODEL") or _cfg["groq"].get("model", "openai/gpt-oss-120b")
ENDPOINT = os.environ.get("GROQ_ENDPOINT") or _cfg["groq"].get(
    "endpoint", "https://api.groq.com/openai/v1/chat/completions"
)

DEFAULT_PROMPT = (
    "You are an experienced Turkish/English editor. Convert ASR/dictation "
    "output into natural, concise, grammatically correct text. Do not be "
    "word-for-word literal; preserve the speaker's intent. Fix or drop "
    "garbled ASR fragments. Do not translate. Keep technical terms, "
    "commands, file paths, and code names unchanged. "
    "PRESERVE THE ORIGINAL LANGUAGE: Turkish input → Turkish output, "
    "English input → English output. "
    "Output only the cleaned text."
)
SYSTEM_PROMPT = _cfg["dictation"].get("system_prompt", DEFAULT_PROMPT)


def should_skip(text: str) -> bool:
    words = re.findall(r"\S+", text)
    if len(text) < 90 and len(words) < 14:
        return True

    code_markers = ["&&", "||", "sudo ", "git ", "docker ", "systemctl ", "journalctl ", "~/", "./", "--"]
    lowered = text.lower()
    if any(marker in lowered for marker in code_markers):
        return True

    return False


def get_api_key() -> str:
    key = os.environ.get("GROQ_API_KEY")
    if key:
        return key
    key = _cfg["groq"].get("api_key", "")
    if key:
        return key
    if KEY_FILE.exists():
        return KEY_FILE.read_text(encoding="utf-8").strip()
    return ""


def clean(text: str) -> str:
    system = SYSTEM_PROMPT
    user = f"""Kurallar:
- D\xfczg\xfcn, do\u011fal ve okunabilir yaz.
- Metnin dilini koru: T\xfcrk\xe7e par\xe7alar T\xfcrk\xe7e, English parts stay in English.
- "\xe7al\u0131\u015f\u0131yor de\u011fil" gibi ifadeleri "\xe7al\u0131\u015fm\u0131yor" gibi do\u011fal hale getir.
- "emin miyseniz emin miyiz \xe7al\u0131\u015f\u0131yor mu diye" gibi bozuk par\xe7alar\u0131 "\xe7al\u0131\u015f\u0131p \xe7al\u0131\u015fmad\u0131\u011f\u0131ndan emin de\u011filim" gibi do\u011fal hale getir.
- "letmiyordur" gibi anlams\u0131z ASR kelimelerini ba\u011flama g\xf6re d\xfczelt.
- Gereksiz tekrarlar\u0131 ve dolgu ifadelerini sil.
- Yeni bilgi ekleme; belirsiz yerde en olas\u0131 anlam\u0131 se\xe7.

MET\u0130N:
{text}"""

    api_key = get_api_key()
    if not api_key:
        raise RuntimeError("GROQ_API_KEY is not configured")

    payload = {
        "model": MODEL,
        "messages": [
            {"role": "system", "content": system},
            {"role": "user", "content": user},
        ],
        "temperature": 0.0,
        "max_completion_tokens": 4096,
    }

    if MODEL.startswith("openai/gpt-oss"):
        payload["reasoning_effort"] = "low"
    elif MODEL.startswith("qwen/"):
        payload["reasoning_effort"] = "none"

    req = urllib.request.Request(
        ENDPOINT,
        data=json.dumps(payload).encode("utf-8"),
        headers={
            "Authorization": f"Bearer {api_key}",
            "Content-Type": "application/json",
            "User-Agent": "voxtype-dictation-cleaner/1.0",
        },
    )

    with urllib.request.urlopen(req, timeout=3.5) as response:
        data = json.loads(response.read().decode("utf-8"))

    choices = data.get("choices") or []
    output = choices[0].get("message", {}).get("content", "").strip() if choices else ""
    output = output.strip('"').strip()
    return output


def _notify(text: str) -> None:
    MAX_LEN = 100
    body = text[:MAX_LEN].replace("\n", " ").strip()
    if len(text) > MAX_LEN:
        body += "…"
    try:
        subprocess.run(
            ["notify-send", "--icon=audio-input-microphone",
             "--app-name=smart-dictate", "Dikte edildi", body],
            timeout=3.0,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
    except Exception:
        pass


def main() -> int:
    original = sys.stdin.read()
    text = original.strip()

    if not text:
        return 0

    if should_skip(text):
        sys.stdout.write(original)
        _notify(text)
        return 0

    try:
        output = clean(text)
    except (TimeoutError, RuntimeError, urllib.error.URLError, json.JSONDecodeError, OSError):
        sys.stdout.write(original)
        _notify(text)
        return 0

    if not output:
        sys.stdout.write(original)
        _notify(text)
        return 0

    if len(output) > max(len(text) * 1.5, len(text) + 120):
        sys.stdout.write(original)
        _notify(text)
        return 0

    sys.stdout.write(output)
    _notify(output)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
